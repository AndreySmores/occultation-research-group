---
import People from '../components/People.astro';
import Results from '../components/Results.astro';
import Publications from '../components/Publications.astro';
import NewsList from '../components/NewsList.astro';
import OccultationMaps from '../components/OccultationMaps.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Occultation Research Group - Advancing our understanding of small bodies through stellar occultation observations" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>The Occultation Group at UVA</title>
    
    <!-- Preload critical resources -->
    <link rel="preload" href="/styles/global.css" as="style" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://occultationgroup.org/" />
    <meta property="og:title" content="The Occultation Group at UVA" />
    <meta property="og:description" content="Advancing our understanding of small bodies through stellar occultation observations" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://occultationgroup.org" />
    <meta property="twitter:title" content="The Occultation Group at UVA" />
    <meta property="twitter:description" content="Advancing our understanding of small bodies through stellar occultation observations" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <Header currentPage="home" />

    <div class="home-banner">
      <img
        src="/images/exec_news_image.jpg"
        alt="Occultation Research Group executive team"
        class="home-banner__image"
        width="1600"
        height="500"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <main id="main-content" class="main" role="main">
      <div class="container">
        <div class="three-column-layout">
          <!-- Left Column: People -->
          <aside class="people-column" role="complementary" aria-label="People and contacts">
            <People />
          </aside>

          <!-- Center Column: Results -->
          <section id="results" class="results-column" aria-label="Research results and publications">
            <Results />
            <OccultationMaps compact={true} />
          </section>

          <!-- Right Column: News -->
          <aside id="news" class="news-column" role="complementary" aria-label="Latest news and updates">
            <Publications />
            <NewsList />
          </aside>
        </div>

      </div>
    </main>

    <Footer />

    <!-- Analytics placeholder - uncomment and configure as needed -->
    <!-- 
    <script defer data-domain="your-domain.com" src="https://plausible.io/js/script.js"></script>
    -->
    
    <!-- Google Analytics placeholder - uncomment and configure as needed -->
    <!--
    <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'GA_MEASUREMENT_ID');
    </script>
    -->
  </body>
</html>

<style>
  .home-banner {
    width: 100%;
    max-height: min(62vh, 640px);
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-secondary);
  }

  .home-banner__image {
    display: block;
    width: 100%;
    height: min(62vh, 640px);
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 768px) {
    .home-banner {
      max-height: min(48vh, 420px);
    }

    .home-banner__image {
      height: min(48vh, 420px);
    }
  }
</style>
